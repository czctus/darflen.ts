{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ],
    "paths": {
      "darflen.ts": [
        "./src/index.ts"
      ],
      "darflen.ts/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ]
}